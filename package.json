{
	"name": "website_rinrin",
	"version": "1.0.7",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "pnpm run licenses && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"licenses": "node assets/scripts/collect-licenses.ts",
		"article": "tsx assets/scripts/create-article.ts",
		"artwork": "tsx assets/scripts/create-artwork.ts",
		"project": "tsx assets/scripts/create-project.ts"
	},
	"packageManager": "pnpm@10.33.0",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.33.0",
			"onFail": "warn"
		}
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@quantco/pnpm-licenses": "^2.4.2",
		"@types/node": "^25.9.3",
		"@typescript-eslint/eslint-plugin": "^8.61.1",
		"@typescript-eslint/parser": "^8.61.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"rollup-plugin-license": "^3.7.1",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.8.0",
		"svelte-preprocess": "^6.0.5",
		"typescript-eslint": "^8.61.1"
	},
	"type": "module",
	"dependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.65.2",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/nprogress": "^0.2.3",
		"chart.js": "^4.5.1",
		"nprogress": "^0.2.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "^6.0.0",
		"sass": "^1.101.0",
		"shiki": "^4.2.0",
		"svelte": "^5.56.3",
		"svelte-chartjs": "^4.0.1",
		"svelte-french-toast": "^1.2.0",
		"svelte-i18n": "^4.0.1",
		"tslib": "^2.8.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"uuid": "^14.0.0",
		"vite": "^8.0.16"
	}
}
